  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-changelog-staged.sh",
            "statusMessage": "Checking changelog is staged..."
          }
        ]
      },
      {
        "matcher": "Bash(rm -rf*)",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A destructive rm -rf command is about to run. Review the target path and determine if this is safe. Block if it targets the repo root, home directory, or system paths. Allow if it targets node_modules, dist, build, or other generated directories."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\\.(svelte|ts|js|json|jsonc)\"'; then npx @biomejs/biome check --write \"$(echo \"$TOOL_INPUT\" | grep -oP '\"file_path\":\\s*\"\\K[^\"]+')\" 2>/dev/null; fi",
            "statusMessage": "Auto-formatting with Biome..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\a'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\a'"
          }
        ]
      }
    ]
  },
  "plansDirectory": "tasks"
}
