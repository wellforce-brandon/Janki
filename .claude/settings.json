{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": ["Read", "Glob", "Grep", "WebFetch", "WebSearch"],
		"deny": [
			"Read(~/.ssh/**)",
			"Read(~/.aws/**)",
			"Read(~/.azure/**)",
			"Read(~/.kube/**)",
			"Read(~/.docker/config.json)",
			"Read(~/.npmrc)",
			"Read(~/.git-credentials)",
			"Read(~/.config/gh/**)",
			"Edit(~/.ssh/**)",
			"Edit(~/.aws/**)",
			"Edit(~/.azure/**)",
			"Edit(~/.kube/**)",
			"Edit(~/.docker/**)",
			"Edit(~/.npmrc)",
			"Edit(~/.gitconfig)",
			"Edit(~/.git-credentials)",
			"Edit(~/.bashrc)",
			"Edit(~/.zshrc)",
			"Edit(~/.profile)",
			"Edit(~/.bash_history)",
			"Edit(~/.zsh_history)",
			"Edit(**/.env)",
			"Edit(**/.env.local)",
			"Edit(**/.env.*.local)",
			"Edit(**/*.pem)",
			"Edit(**/*.key)",
			"Edit(**/*.cert)"
		]
	},
	"env": {
		"ENABLE_TOOL_SEARCH": "true"
	},
	"plansDirectory": "tasks",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash(git commit*)",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/check-changelog-staged.sh",
						"statusMessage": "Checking changelog is staged..."
					}
				]
			},
			{
				"matcher": "Bash(rm -rf*)",
				"hooks": [
					{
						"type": "prompt",
						"prompt": "A destructive rm -rf command is about to run. Review the target path and determine if this is safe. Block if it targets the repo root, home directory, or system paths. Allow if it targets node_modules, dist, build, or other generated directories."
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "if echo \"$TOOL_INPUT\" | grep -qE '\\.(svelte|ts|js|json|jsonc)\"'; then npx @biomejs/biome check --write \"$(echo \"$TOOL_INPUT\" | grep -oP '\"file_path\":\\s*\"\\K[^\"]+')\" 2>/dev/null; fi",
						"statusMessage": "Auto-formatting with Biome..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "echo '\\a'"
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "echo '\\a'"
					}
				]
			}
		]
	}
}
