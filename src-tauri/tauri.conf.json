{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Janki",
  "version": "0.2.0",
  "identifier": "com.janki.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:7755",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Janki",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
