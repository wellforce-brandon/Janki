{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Janki",
  "version": "0.19.0",
  "identifier": "com.janki.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:7755",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Janki",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxNEI2MEM1RUFBNDcwRjYKUldUMmNLVHF4V0JMc1lrUEMzY1M4NnEvNDJJaXpEdEFpaWxqdm1sMUNxV0VIQ2pjaElkYkI3ZTQK",
      "endpoints": [
        "https://github.com/wellforce-brandon/Janki/releases/latest/download/latest.json"
      ]
    }
  }
}
